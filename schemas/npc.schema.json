{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tl-ai.local/schemas/npc.schema.json",
  "title": "Npc",
  "description": "NPC specification (Entity Model V2). Stored under specifications/npc/.",
  "allOf": [
    {
      "$ref": "entity.schema.json"
    }
  ],
  "properties": {
    "id": {
      "pattern": "^tl\\.npc\\.[a-z0-9_]+$"
    },
    "type": {
      "const": "Npc"
    },
    "role": {
      "$ref": "common.schema.json#/$defs/NpcRole"
    },
    "location": {
      "description": "Location name (free text until a Zone entity type exists).",
      "type": "string",
      "minLength": 1
    },
    "services": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "sells": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/ItemReference" },
      "uniqueItems": true
    }
  },
  "required": ["role", "location"],
  "unevaluatedProperties": false
}
