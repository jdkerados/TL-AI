{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tl-ai.local/schemas/monster.schema.json",
  "title": "Monster",
  "description": "Monster specification (Entity Model V2). Stored under specifications/monsters/.",
  "allOf": [
    {
      "$ref": "entity.schema.json"
    }
  ],
  "properties": {
    "id": {
      "pattern": "^tl\\.monster\\.[a-z0-9_]+$"
    },
    "type": {
      "const": "Monster"
    },
    "grade": {
      "type": "string",
      "enum": ["Normal", "Elite", "Named"]
    },
    "level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 70
    },
    "family": {
      "$ref": "common.schema.json#/$defs/MonsterFamily"
    },
    "combatStats": {
      "description": "Strongly typed combat stats. Must include Health, Defense, MagicDefense, and Attack or MagicAttack.",
      "$ref": "common.schema.json#/$defs/StatModifierList"
    },
    "skills": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/SkillReference" },
      "uniqueItems": true
    },
    "drops": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/MonsterDrop" }
    },
    "zone": {
      "description": "Zone name (free text until a Zone entity type exists).",
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["grade", "level", "family", "combatStats"],
  "unevaluatedProperties": false
}
