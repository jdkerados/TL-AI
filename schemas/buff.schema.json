{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tl-ai.local/schemas/buff.schema.json",
  "title": "Buff",
  "description": "Buff/Debuff specification (Entity Model V2). Stored under specifications/buffs/.",
  "allOf": [
    {
      "$ref": "entity.schema.json"
    },
    {
      "oneOf": [{ "required": ["duration"] }, { "required": ["permanent"] }]
    },
    {
      "anyOf": [
        { "required": ["modifiers"] },
        { "required": ["tick"] },
        { "required": ["crowdControl"] }
      ]
    }
  ],
  "properties": {
    "id": {
      "pattern": "^tl\\.buff\\.[a-z0-9_]+$"
    },
    "type": {
      "const": "Buff"
    },
    "buffCategory": {
      "type": "string",
      "enum": ["Buff", "Debuff"]
    },
    "dispellable": {
      "type": "boolean"
    },
    "maxStacks": {
      "type": "integer",
      "minimum": 1
    },
    "duration": {
      "description": "Effect duration in seconds.",
      "type": "number",
      "exclusiveMinimum": 0
    },
    "permanent": {
      "description": "Permanent effect (mutually exclusive with duration).",
      "const": true
    },
    "modifiers": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/StatModifier" },
      "minItems": 1
    },
    "tick": {
      "$ref": "common.schema.json#/$defs/TickEffect"
    },
    "crowdControl": {
      "$ref": "common.schema.json#/$defs/CrowdControlKind"
    }
  },
  "required": ["buffCategory", "dispellable", "maxStacks"],
  "unevaluatedProperties": false
}
