{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tl-ai.local/schemas/weapon.schema.json",
  "title": "Weapon",
  "description": "Weapon item specification (Entity Model V2). Stored under specifications/items/weapons/.",
  "allOf": [
    {
      "$ref": "item.schema.json"
    },
    {
      "properties": {
        "baseStats": {
          "allOf": [
            {
              "contains": {
                "type": "object",
                "properties": { "attribute": { "const": "MinDamage" } },
                "required": ["attribute"]
              }
            },
            {
              "contains": {
                "type": "object",
                "properties": { "attribute": { "const": "MaxDamage" } },
                "required": ["attribute"]
              }
            }
          ]
        }
      }
    }
  ],
  "properties": {
    "id": {
      "pattern": "^tl\\.weapon\\.[a-z0-9_]+$"
    },
    "type": {
      "const": "Weapon"
    },
    "weaponType": {
      "$ref": "common.schema.json#/$defs/WeaponType"
    },
    "grantsSkills": {
      "description": "Skills granted by this weapon (typed references).",
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/SkillReference" },
      "uniqueItems": true
    }
  },
  "required": ["weaponType"],
  "unevaluatedProperties": false
}
