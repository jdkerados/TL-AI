{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tl-ai.local/schemas/weapon.schema.json",
  "title": "Weapon",
  "description": "Weapon item specification. Stored under specifications/items/weapons/.",
  "allOf": [
    {
      "$ref": "item.schema.json"
    }
  ],
  "properties": {
    "id": {
      "pattern": "^tl\\.weapon\\.[a-z0-9_]+$"
    },
    "type": {
      "const": "Weapon"
    }
  },
  "unevaluatedProperties": false
}
