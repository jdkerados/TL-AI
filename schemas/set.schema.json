{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tl-ai.local/schemas/set.schema.json",
  "title": "SetBonus",
  "description": "Set bonus specification (Entity Model V2). Stored under specifications/sets/. The stable-ID category remains tl.set.* (stable IDs are immutable); the entity type is SetBonus.",
  "allOf": [
    {
      "$ref": "entity.schema.json"
    }
  ],
  "properties": {
    "id": {
      "pattern": "^tl\\.set\\.[a-z0-9_]+$"
    },
    "type": {
      "const": "SetBonus"
    },
    "rarity": {
      "$ref": "common.schema.json#/$defs/Rarity"
    },
    "members": {
      "description": "Items belonging to this set (canonical side; items do not reference sets).",
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/ItemReference" },
      "minItems": 2,
      "uniqueItems": true
    },
    "bonuses": {
      "description": "Piece-count bonuses.",
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/PieceBonus" },
      "minItems": 1
    }
  },
  "required": ["rarity", "members", "bonuses"],
  "unevaluatedProperties": false
}
