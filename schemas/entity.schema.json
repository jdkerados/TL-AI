{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tl-ai.local/schemas/entity.schema.json",
  "title": "Entity",
  "description": "Base schema for every TL-AI specification entity. All concrete entity schemas extend this schema via allOf.",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "common.schema.json#/$defs/StableId"
    },
    "type": {
      "description": "Entity type discriminator (PascalCase). Concrete schemas constrain this to a constant.",
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9]*$"
    },
    "name": {
      "$ref": "common.schema.json#/$defs/PascalCaseName"
    },
    "description": {
      "description": "Human-readable description of the entity.",
      "type": "string"
    },
    "version": {
      "$ref": "common.schema.json#/$defs/SemanticVersion"
    },
    "patch": {
      "$ref": "common.schema.json#/$defs/GamePatch"
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/Metadata"
    }
  },
  "required": ["id", "type", "name", "version", "patch", "metadata"]
}
